{
	"info": {
		"_postman_id": "360ghar-api-collection",
		"name": "360Ghar Real Estate Platform API",
		"description": "Complete API collection for 360Ghar - Tinder-like real estate platform with Supabase integration.\n\n## Setup Instructions:\n1. Import this collection into Postman\n2. Create/Import the environment variables\n3. Update SUPABASE_URL and SUPABASE_KEY in environment\n4. Start with Login endpoint to get access token\n5. Token will be automatically saved and used for subsequent requests\n\n## Features:\n- Automatic token management\n- Response validation tests\n- Example data for all requests\n- Performance monitoring\n- Error handling",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "360ghar"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Global Pre-request Script",
					"// Set request ID for tracking",
					"pm.variables.set('request_id', pm.variables.replaceIn('{{$guid}}'));",
					"",
					"// Set timestamp",
					"pm.variables.set('timestamp', new Date().toISOString());",
					"",
					"// Check if token exists and is not expired",
					"const tokenExpiry = pm.environment.get('token_expiry');",
					"if (tokenExpiry) {",
					"    const now = new Date().getTime();",
					"    const expiry = new Date(tokenExpiry).getTime();",
					"    ",
					"    if (now >= expiry) {",
					"        console.log('Token expired, please login again');",
					"        pm.environment.unset('access_token');",
					"        pm.environment.unset('token_expiry');",
					"    }",
					"}",
					"",
					"// Set common headers",
					"pm.request.headers.add({",
					"    key: 'X-Request-ID',",
					"    value: pm.variables.get('request_id')",
					"});",
					"",
					"// Log request details",
					"console.log(`Making ${pm.request.method} request to ${pm.request.url}`);",
					"",
					"// Generate sample data helpers",
					"pm.variables.set('randomEmail', pm.variables.replaceIn('{{$randomEmail}}'));",
					"pm.variables.set('randomPhone', '+91' + Math.floor(Math.random() * 9000000000 + 1000000000));",
					"pm.variables.set('randomName', pm.variables.replaceIn('{{$randomFullName}}'));",
					"pm.variables.set('randomPrice', Math.floor(Math.random() * 50000000 + 1000000));",
					"pm.variables.set('randomBedrooms', Math.floor(Math.random() * 4 + 1));",
					"pm.variables.set('randomArea', Math.floor(Math.random() * 3000 + 500));",
					"pm.variables.set('futureDate', new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString());"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Global Test Script",
					"// Log response time",
					"console.log(`Response time: ${pm.response.responseTime}ms`);",
					"",
					"// Check for performance issues",
					"if (pm.response.responseTime > 2000) {",
					"    console.warn(`Slow response detected: ${pm.response.responseTime}ms`);",
					"}",
					"",
					"// Parse response if JSON",
					"let jsonResponse = null;",
					"try {",
					"    jsonResponse = pm.response.json();",
					"    pm.environment.set('last_response', JSON.stringify(jsonResponse));",
					"} catch (e) {",
					"    // Not JSON response",
					"}",
					"",
					"// Common test for all endpoints",
					"pm.test('Response has correct content type', function() {",
					"    const contentType = pm.response.headers.get('Content-Type');",
					"    if (contentType) {",
					"        pm.expect(contentType).to.include('application/json');",
					"    }",
					"});",
					"",
					"// Check for common error patterns",
					"if (pm.response.code >= 400) {",
					"    pm.test('Error response has proper structure', function() {",
					"        if (jsonResponse) {",
					"            pm.expect(jsonResponse).to.have.property('detail');",
					"        }",
					"    });",
					"}"
				]
			}
		}
	],
