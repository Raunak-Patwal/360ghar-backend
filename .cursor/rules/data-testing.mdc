### Common Test Scenarios

#### User Registration Flow
```javascript
// Postman test script
pm.test("Status code is 201", function () {
    pm.response.to.have.status(201);
});

pm.test("Response has required fields", function () {
    var jsonData = pm.response.json();
    pm.expect(jsonData).to.have.property('id');
    pm.expect(jsonData).to.have.property('email');
    pm.expect(jsonData).to.have.property('created_at');
});

// Save token for subsequent requests
var jsonData = pm.response.json();
pm.collectionVariables.set("user_id", jsonData.id);
```

#### Property Search Flow
```javascript
pm.test("Returns properties array", function () {
    var jsonData = pm.response.json();
    pm.expect(jsonData).to.be.an('array');
});

pm.test("Properties have required fields", function () {
    var jsonData = pm.response.json();
    if (jsonData.length > 0) {
        pm.expect(jsonData[0]).to.have.property('id');
        pm.expect(jsonData[0]).to.have.property('title');
        pm.expect(jsonData[0]).to.have.property('price');
    }
});
```

## Development Workflow

### Local Development Setup
```bash
# 1. Set up virtual environment
python -m venv venv
source venv/bin/activate  # On macOS/Linux
# or on Windows: venv\Scripts\activate

# 2. Install dependencies
pip install -r requirements.txt

# 3. Set up environment variables
cp .env.example .env
# Configure: DATABASE_URL, SUPABASE_URL, SUPABASE_KEY, etc.

# 4. Run database migrations
supabase db reset  # Reset local database
supabase db push   # Apply migrations

# 5. Populate test data
python populate_data/load_comprehensive_data.py --quick  # Quick test data
# or
python populate_data/load_comprehensive_data.py          # Full dataset

# 6. Start development server
python run.py
# or
uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
```

### Testing Workflow
```bash
# Run all async tests
pytest tests/ -v --asyncio-mode=auto

# Run specific test file
pytest tests/test_user_service.py -v --asyncio-mode=auto

# Run tests with coverage
pytest tests/ --cov=app --cov-report=html --asyncio-mode=auto

# Run tests for specific module
pytest tests/ -k "user" -v --asyncio-mode=auto

# Run tests in parallel (be careful with database conflicts)
pytest tests/ -n auto --asyncio-mode=auto

# Run tests with detailed output
pytest tests/ -v -s --tb=short --asyncio-mode=auto
```

