## Testing Patterns

### Async Test Structure
```python
# Located in tests/ - All tests use async patterns
import pytest
from sqlalchemy.ext.asyncio import AsyncSession
from app.services.user import get_or_create_user_from_supabase
from app.schemas.user import UserCreate

class TestUserService:
    @pytest.mark.asyncio
    async def test_get_or_create_user_from_supabase(self, test_db: AsyncSession):
        """Test Supabase user synchronization"""
        # Mock Supabase user data
        supabase_data = {
            "id": "test-supabase-id",
            "email": "test@example.com",
            "phone": "+919876543210",
            "user_metadata": {"full_name": "Test User"},
            "email_verified": True
        }

        user = await get_or_create_user_from_supabase(test_db, supabase_data)

        assert user.supabase_user_id == "test-supabase-id"
        assert user.email == "test@example.com"
        assert user.phone == "+919876543210"
        assert user.full_name == "Test User"
        assert user.is_verified == True

    @pytest.mark.asyncio
    async def test_user_update(self, test_db: AsyncSession):
        """Test user profile updates"""
        # Create test user first
        user_data = {
            "supabase_user_id": "test-id",
            "phone": "+919876543210",
            "full_name": "Original Name",
            "is_active": True,
            "is_verified": True
        }
        user = User(**user_data)
        test_db.add(user)
        await test_db.commit()
        await test_db.refresh(user)

        # Test update
        update_data = {"full_name": "Updated Name", "email": "new@example.com"}
        updated_user = await update_user(test_db, user.id, update_data)

        assert updated_user.full_name == "Updated Name"
        assert updated_user.email == "new@example.com"
```

### Async Test Fixtures and Utilities
```python
# Located in tests/conftest.py
import pytest
from sqlalchemy.ext.asyncio import create_async_engine, AsyncSession
from sqlalchemy.orm import sessionmaker
from app.core.database import Base

@pytest.fixture
async def test_db():
    """Async test database fixture with proper cleanup"""
    engine = create_async_engine("sqlite+aiosqlite:///:memory:", echo=False)

    # Create all tables
    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)

    # Create session factory
    async_session = sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)

    async with async_session() as session:
        yield session

    # Cleanup
    await engine.dispose()

# Test utilities
async def create_test_user(db: AsyncSession, **overrides) -> User:
    """Create a test user with default values and optional overrides"""
    user_data = {
        "supabase_user_id": f"test-{random.randint(1000, 9999)}",
        "phone": "+919876543210",
        "full_name": "Test User",
        "email": "test@example.com",
        "is_active": True,
        "is_verified": True,
        **overrides  # Allow overriding defaults
    }
    user = User(**user_data)
    db.add(user)
    await db.commit()
    await db.refresh(user)
    return user

async def create_test_property(db: AsyncSession, owner_id: int, **overrides) -> Property:
    """Create a test property with realistic data"""
    property_data = {
        "title": "Test Property",
        "description": "A beautiful test property",
        "property_type": PropertyType.apartment,
        "purpose": PropertyPurpose.rent,
        "base_price": 25000,
        "city": "Mumbai",
        "latitude": 19.0760,
        "longitude": 72.8777,
        "owner_id": owner_id,
        "is_available": True,
        **overrides
    }
    property = Property(**property_data)
    db.add(property)
    await db.commit()
    await db.refresh(property)
    return property
```

## Database Migration Testing

### Supabase Migrations
```sql
-- Located in supabase/migrations/
-- Migration files are named with timestamps:
-- YYYYMMDDHHMMSS_description.sql

-- Example migration structure:
BEGIN;

-- Create new table
CREATE TABLE example_table (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name VARCHAR(255) NOT NULL,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- Add new column to existing table
ALTER TABLE properties ADD COLUMN new_feature BOOLEAN DEFAULT FALSE;

-- Create index for performance
CREATE INDEX idx_properties_new_feature ON properties(new_feature);

COMMIT;
```

### Migration Testing
```bash
# Test migrations locally before deploying
supabase db reset  # Reset local database
supabase db push   # Apply migrations

# Check migration status
supabase db diff   # See pending changes
```

