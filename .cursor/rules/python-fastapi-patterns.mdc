## Error Handling Patterns

### Custom Exceptions
```python
# Located in app/core/exceptions.py
class AppBaseException(Exception):
    def __init__(self, message: str, status_code: int = 400):
        self.message = message
        self.status_code = status_code
        super().__init__(self.message)

class UserNotFoundException(AppBaseException):
    def __init__(self, user_id: UUID):
        super().__init__(f"User with ID {user_id} not found", 404)

class PropertyNotFoundException(AppBaseException):
    def __init__(self, property_id: UUID):
        super().__init__(f"Property with ID {property_id} not found", 404)
```

### Global Exception Handler
```python
# Located in app/main.py or app/core/exceptions.py
from fastapi import Request, HTTPException
from fastapi.responses import JSONResponse

@app.exception_handler(AppBaseException)
async def app_exception_handler(request: Request, exc: AppBaseException):
    return JSONResponse(
        status_code=exc.status_code,
        content={"detail": exc.message}
    )

@app.exception_handler(HTTPException)
async def http_exception_handler(request: Request, exc: HTTPException):
    return JSONResponse(
        status_code=exc.status_code,
        content={"detail": exc.detail}
    )
```

## Database Patterns

### Async Transaction Management
```python
# Async database operations with proper transaction handling
async def create_booking_with_visit(
    db: AsyncSession,
    booking_data: dict,
    visit_data: dict
) -> Tuple[Booking, Visit]:
    """Create booking and visit in a single transaction"""
    try:
        # Create booking
        booking = Booking(**booking_data)
        db.add(booking)
        await db.flush()  # Get booking ID without committing

        # Create visit linked to booking
        visit_data["booking_id"] = booking.id
        visit = Visit(**visit_data)
        db.add(visit)
        await db.flush()

        # Both objects are ready for commit
        await db.refresh(booking)
        await db.refresh(visit)

        return booking, visit

    except Exception as e:
        await db.rollback()
        logger.error(f"Transaction failed: {str(e)}")
        raise

# Usage in service
async def schedule_visit_with_booking(self, db: AsyncSession, data: VisitBookingData):
    async with db.begin():  # Auto-commits on success, rolls back on error
        return await create_booking_with_visit(db, data.booking, data.visit)
```

### Advanced Query Patterns with PostGIS and Full-Text Search
```python
# PostGIS distance search
async def get_properties_within_radius(
    db: AsyncSession,
    latitude: float,
    longitude: float,
    radius_km: int = 5
) -> List[Property]:
    """Find properties within radius using PostGIS"""
    from geoalchemy2 import func as geofunc

    # Create center point
    center_point = geofunc.ST_SetSRID(geofunc.ST_MakePoint(longitude, latitude), 4326)

    stmt = (
        select(Property)
        .where(
            geofunc.ST_DWithin(
                Property.location,  # Geography column
                center_point,
                radius_km * 1000  # Convert km to meters
            )
        )
        .order_by(
            geofunc.ST_Distance(Property.location, center_point)
        )
    )

    result = await db.execute(stmt)
    return result.scalars().all()

# Full-text search with ts_vector
async def search_properties_by_text(
    db: AsyncSession,
    search_query: str,
    limit: int = 20
) -> List[Property]:
    """Full-text search using PostgreSQL ts_vector"""
    from sqlalchemy import func

    # Use ts_vector column for fast text search
    stmt = (
        select(Property)
        .where(Property.__ts_vector__.match(search_query, postgresql_regconfig='english'))
        .order_by(func.ts_rank(Property.__ts_vector__, func.plainto_tsquery(search_query)))
        .limit(limit)
    )

    result = await db.execute(stmt)
    return result.scalars().all()

# Complex filtering with joins and aggregations
async def get_property_recommendations(
    db: AsyncSession,
    user_id: int,
    user_preferences: dict,
    limit: int = 10
) -> List[Property]:
    """Complex recommendation query with user preferences"""
    # Subquery for user's liked property types
    liked_types = (
        select(UserSwipe.property_type)
        .where(UserSwipe.user_id == user_id, UserSwipe.is_liked == True)
        .distinct()
    )

    stmt = (
        select(Property, func.count(UserSwipe.id).label('interest_count'))
        .outerjoin(UserSwipe, and_(UserSwipe.property_id == Property.id, UserSwipe.is_liked == True))
        .where(
            Property.is_available == True,
            Property.city.in_(user_preferences.get('preferred_cities', [])),
            Property.property_type.in_(liked_types)
        )
        .group_by(Property.id)
        .order_by(func.count(UserSwipe.id).desc(), Property.created_at.desc())
        .limit(limit)
    )

    result = await db.execute(stmt)
    return [row[0] for row in result.all()]
```

## Configuration Patterns

### Pydantic Settings with Supabase Integration
```python
# Located in app/core/config.py
from pydantic_settings import BaseSettings
from typing import Optional, List

class Settings(BaseSettings):
    # Application
    API_V1_STR: str = "/api/v1"
    ENVIRONMENT: str = "development"
    DEBUG: bool = False

    # Database - Async PostgreSQL with PgBouncer compatibility
    DATABASE_URL: str
    ASYNC_DATABASE_URL: str = None  # Auto-converted from DATABASE_URL

    @property
    def ASYNC_DATABASE_URL(self) -> str:
        """Convert DATABASE_URL to async format for psycopg"""
        url = self.DATABASE_URL
        if url.startswith("postgresql://"):
            url = url.replace("postgresql://", "postgresql+psycopg://", 1)
        return url

    # Supabase Authentication
    SUPABASE_URL: str
    SUPABASE_KEY: str
    SUPABASE_SECRET_KEY: str

    # Optional Redis (for caching)
    REDIS_URL: str = "redis://localhost:6379"

    # Sentry (optional)
    SENTRY_DSN: Optional[str] = None

    # CORS Origins
    CORS_ORIGINS: List[str] = [
        "http://localhost:3000", "http://localhost:5173",  # Development
        "https://360ghar.com", "https://www.360ghar.com"  # Production
    ]

    # File Upload
    SUPABASE_STORAGE_BUCKET: str = "property-images"

    class Config:
        env_file = ".env"
        case_sensitive = True

settings = Settings()
```

## Testing Patterns

### Async Service Testing with Fixtures
```python
# Located in tests/
import pytest
from sqlalchemy.ext.asyncio import create_async_engine, AsyncSession
from sqlalchemy.orm import sessionmaker
from app.core.database import Base

@pytest.fixture
async def test_db():
    """Async test database fixture"""
    engine = create_async_engine("sqlite+aiosqlite:///:memory:", echo=False)

    async with engine.begin() as conn:
        await conn.run_sync(Base.metadata.create_all)

    async_session = sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)

    async with async_session() as session:
        yield session

    await engine.dispose()

@pytest.mark.asyncio
async def test_create_user(test_db: AsyncSession):
    """Test user creation service"""
    user_service = UserService(test_db)

    user_data = {
        "supabase_user_id": "test-supabase-id",
        "email": "test@example.com",
        "phone": "+919876543210",
        "full_name": "Test User",
        "is_active": True,
        "is_verified": True
    }

    user = User(**user_data)
    test_db.add(user)
    await test_db.commit()
    await test_db.refresh(user)

    assert user.email == "test@example.com"
    assert user.phone == "+919876543210"
    assert user.is_active == True

@pytest.mark.asyncio
async def test_property_search_with_filters(test_db: AsyncSession):
    """Test complex property search functionality"""
    # Create test data
    property_data = {
        "title": "Test Property",
        "property_type": "apartment",
        "purpose": "rent",
        "base_price": 25000,
        "city": "Mumbai",
        "owner_id": 1
    }

    property = Property(**property_data)
    test_db.add(property)
    await test_db.commit()

    # Test search service
    results = await get_unified_properties_optimized(
        test_db,
        purpose="rent",
        city="Mumbai",
        min_price=20000,
        max_price=30000
    )

    assert len(results.items) > 0
    assert results.items[0].title == "Test Property"
```

## Best Practices

### Async-First Development
- **Always use async/await** for database operations and external API calls
- **Async database sessions** with proper transaction management
- **Async service methods** for all business logic
- **Async test fixtures** and test functions with `pytest.mark.asyncio`

### Code Organization
- **Service Layer Pattern**: All business logic in async services
- **Schema Validation**: Pydantic schemas for all request/response data
- **Dependency Injection**: FastAPI dependencies for database sessions and auth
- **Error Handling**: Structured error responses with error codes
- **Type Hints**: Full type annotations throughout the codebase

### Database Best Practices
- **Async SQLAlchemy** with proper session management
- **PostGIS** for geospatial queries and distance calculations
- **Full-text search** with PostgreSQL ts_vector for property search
- **Proper indexing** on frequently queried fields
- **Transaction management** with async context managers
- **Connection pooling** for production performance

### Security Best Practices
- **Supabase Authentication** for secure user management
- **Phone as primary identifier** (more secure than email)
- **Role-based access control** with proper permission checks
- **Input validation** with Pydantic field validators
- **SQL injection prevention** through SQLAlchemy ORM
- **Structured error responses** (no sensitive data exposure)
- **CORS configuration** (different for dev/prod environments)

### Performance Optimization
- **Database query optimization** with selectinload and proper joins
- **Caching layer** (Redis) for frequently accessed data
- **Pagination** for all list endpoints
- **PostGIS spatial indexes** for location-based searches
- **Full-text search indexes** for property search
- **Async I/O** for all external service calls

### Testing Best Practices
- **Async test fixtures** for database setup/teardown
- **Comprehensive service testing** with realistic data
- **API endpoint testing** with proper authentication
- **Data population scripts** for development and testing
- **Test data validation** to ensure data integrity

### API Design Patterns
- **RESTful endpoints** with consistent naming conventions
- **Unified filtering** for complex search requirements
- **Structured error responses** with error codes and context
- **Pagination** for all list endpoints
- **Proper HTTP status codes** and response formats
- **OpenAPI documentation** with comprehensive schemas

### Maintainability
- **Modular architecture** with separate concerns
- **Comprehensive logging** with structured JSON format
- **Environment-based configuration** with Pydantic settings
- **Database migrations** with proper versioning
- **Documentation** in code and separate docs
- **Consistent code style** following Python best practices